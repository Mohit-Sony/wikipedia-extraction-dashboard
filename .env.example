# Wikipedia Dashboard - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ==========================================
# Application Settings
# ==========================================
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL=sqlite:///./wikipedia.db
# For PostgreSQL (optional):
# DATABASE_URL=postgresql://user:password@localhost:5432/wikipedia_dashboard

# ==========================================
# Google Drive API Credentials
# ==========================================
# Place your credentials.json file in the project root
# Get it from: https://console.cloud.google.com/apis/credentials
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json

# ==========================================
# Wikidata API Configuration
# ==========================================
WIKIDATA_API_URL=https://www.wikidata.org/w/api.php
WIKIDATA_CACHE_ENABLED=true
WIKIDATA_CACHE_TTL=3600

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/dashboard.log

# ==========================================
# CORS Settings
# ==========================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# For production, add your domain:
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# ==========================================
# API Rate Limiting
# ==========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ==========================================
# WebSocket Configuration
# ==========================================
WEBSOCKET_PING_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10

# ==========================================
# Extraction Service Configuration
# ==========================================
EXTRACTION_BATCH_SIZE=10
EXTRACTION_CONCURRENT_REQUESTS=5
EXTRACTION_RETRY_ATTEMPTS=3

# ==========================================
# Production Settings
# ==========================================
# Set to 'production' when deploying to EC2
ENVIRONMENT=development

# ==========================================
# Security Settings
# ==========================================
# Generate a secure secret key for production
SECRET_KEY=your-secret-key-here-change-in-production

# ==========================================
# Optional: AWS Configuration (if using S3, etc.)
# ==========================================
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your-bucket-name

# ==========================================
# Optional: Email Notifications
# ==========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@yourdomain.com
